<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <PackageId>EffSharp.Gen</PackageId>
    <Version>0.0.1</Version>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/vmenge/EffSharp</PackageProjectUrl>
    <RepositoryUrl>https://github.com/vmenge/EffSharp</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="ProjectInputs.fs" />
    <Compile Include="EffectAttribute.fs" />
    <Compile Include="Model.fs" />
    <Compile Include="Naming.fs" />
    <Compile Include="Classification.fs" />
    <Compile Include="FcsParsing.fs" />
    <Compile Include="Discovery.fs" />
    <Compile Include="Validation.fs" />
    <Compile Include="Emission.fs" />
    <Compile Include="Generation.fs" />
    <Compile Include="GeneratorTask.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.Core" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Microsoft.Build.Framework">
      <HintPath>$(MSBuildBinPath)/Microsoft.Build.Framework.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Microsoft.Build.Utilities.Core">
      <HintPath>$(MSBuildBinPath)/Microsoft.Build.Utilities.Core.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="FSharp.Compiler.Service">
      <HintPath>$(MSBuildBinPath)/FSharp/FSharp.Compiler.Service.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <None Include="..\buildTransitive\EffSharp.Gen.props" Pack="true" PackagePath="buildTransitive\EffSharp.Gen.props" Visible="false" />
    <None Include="..\buildTransitive\EffSharp.Gen.targets" Pack="true" PackagePath="buildTransitive\EffSharp.Gen.targets" Visible="false" />
    <None Include="bin\$(Configuration)\$(TargetFramework)\Gen.dll" Pack="true" PackagePath="buildTransitive\$(TargetFramework)\Gen.dll" Visible="false" />
    <None Include="bin\$(Configuration)\$(TargetFramework)\Gen.deps.json" Pack="true" PackagePath="buildTransitive\$(TargetFramework)\Gen.deps.json" Visible="false" />
    <None Include="bin\$(Configuration)\$(TargetFramework)\FSharp.Core.dll" Pack="true" PackagePath="buildTransitive\$(TargetFramework)\FSharp.Core.dll" Visible="false" />
    <None Include="bin\$(Configuration)\$(TargetFramework)\FSharp.Compiler.Service.dll" Pack="true" PackagePath="buildTransitive\$(TargetFramework)\FSharp.Compiler.Service.dll" Visible="false" />
  </ItemGroup>

</Project>
