<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>EffSharp.Core</PackageId>
    <Version>0.0.1</Version>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/vmenge/EffSharp</PackageProjectUrl>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Report.fs" />
    <Compile Include="EffTypes.fs" />
    <Compile Include="EffRuntime.fs" />
    <Compile Include="EffNodes.fs" />
    <Compile Include="EffApi.fs" />
    <Compile Include="CE.fs" />
    <Compile Include="ReportCE.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.Core" />
  </ItemGroup>

</Project>
