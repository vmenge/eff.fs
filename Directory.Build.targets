<Project>
  <PropertyGroup>
    <_GenSourceProjectPath>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)pkgs/Gen/src/Gen.fsproj'))</_GenSourceProjectPath>
    <_GenToolProjectPath>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)pkgs/Gen/tool/Gen.Tool.fsproj'))</_GenToolProjectPath>
    <_GenTestsProjectPath>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)pkgs/Gen/tests/Gen.Tests.fsproj'))</_GenTestsProjectPath>
    <_GenToolDllPath>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)pkgs/Gen/tool/bin/$(Configuration)/net10.0/Gen.Tool.dll'))</_GenToolDllPath>
  </PropertyGroup>

  <Target
    Name="GenGenerateSourcesFromProjectReference"
    BeforeTargets="FSharpSourceCodeCompileOrder"
    Condition="'$(Language)' == 'F#' and '$(GenSourceMode)' != 'false' and '$(MSBuildProjectFullPath)' != '$(_GenSourceProjectPath)' and '$(MSBuildProjectFullPath)' != '$(_GenToolProjectPath)' and '$(MSBuildProjectFullPath)' != '$(_GenTestsProjectPath)'">
    <ItemGroup>
      <_GenSourceProjectReference
        Include="@(ProjectReference)"
        Condition="'%(FullPath)' != '' and '%(FullPath)' == '$(_GenSourceProjectPath)'" />
    </ItemGroup>

    <PropertyGroup Condition="'@(_GenSourceProjectReference)' != ''">
      <_GenGeneratedDirectory>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)/$(IntermediateOutputPath)Gen'))</_GenGeneratedDirectory>
      <_GenCompileItemsFile>$(_GenGeneratedDirectory)\compile-items.txt</_GenCompileItemsFile>
      <_GenParseArgsFile>$(_GenGeneratedDirectory)\parse-args.txt</_GenParseArgsFile>
      <_GenOtherFlagsFile>$(_GenGeneratedDirectory)\other-flags.txt</_GenOtherFlagsFile>
      <_GenOrderedCompileItemsFile>$(_GenGeneratedDirectory)\ordered-compile-items.txt</_GenOrderedCompileItemsFile>
    </PropertyGroup>

    <ItemGroup Condition="'@(_GenSourceProjectReference)' != ''">
      <_GenDefine Include="$(DefineConstants)" Condition="'$(DefineConstants)' != ''" />
      <_GenParseCommandLineArg Include="--targetprofile:$(TargetProfile)" Condition="'$(TargetProfile)' != ''" />
      <_GenParseCommandLineArg Include="--langversion:$(LangVersion)" Condition="'$(LangVersion)' != ''" />
      <_GenParseCommandLineArg Include="@(_GenDefine->'--define:%(Identity)')" />
      <_GenParseCommandLineArg Include="@(DisabledLanguageFeatures->'--disable-language-feature:%(Identity)')" />
      <_GenParseCommandLineArg Include="@(ReferencePath->'--reference:%(FullPath)')" Condition="'@(ReferencePath)' != ''" />
    </ItemGroup>

    <MSBuild
      Projects="$(_GenToolProjectPath)"
      Targets="Build"
      Properties="Configuration=$(Configuration)"
      Condition="'@(_GenSourceProjectReference)' != ''" />

    <MakeDir
      Directories="$(_GenGeneratedDirectory)"
      Condition="'@(_GenSourceProjectReference)' != ''" />

    <WriteLinesToFile
      File="$(_GenCompileItemsFile)"
      Lines="@(Compile->'%(FullPath)')"
      Overwrite="true"
      Condition="'@(_GenSourceProjectReference)' != ''" />

    <WriteLinesToFile
      File="$(_GenParseArgsFile)"
      Lines="@(_GenParseCommandLineArg)"
      Overwrite="true"
      Condition="'@(_GenSourceProjectReference)' != ''" />

    <WriteLinesToFile
      File="$(_GenOtherFlagsFile)"
      Lines="$(OtherFlags)"
      Overwrite="true"
      Condition="'@(_GenSourceProjectReference)' != ''" />

    <Exec
      Command="dotnet &quot;$(_GenToolDllPath)&quot; --project-directory &quot;$(MSBuildProjectDirectory)&quot; --intermediate-output-path &quot;$(IntermediateOutputPath)&quot; --compile-items-file &quot;$(_GenCompileItemsFile)&quot; --parse-args-file &quot;$(_GenParseArgsFile)&quot; --ordered-compile-items-file &quot;$(_GenOrderedCompileItemsFile)&quot; --other-flags-file &quot;$(_GenOtherFlagsFile)&quot;"
      ConsoleToMsBuild="true"
      Condition="'@(_GenSourceProjectReference)' != ''" />

    <ReadLinesFromFile
      File="$(_GenOrderedCompileItemsFile)"
      Condition="'@(_GenSourceProjectReference)' != ''">
      <Output TaskParameter="Lines" ItemName="_GenOrderedCompile" />
    </ReadLinesFromFile>

    <ItemGroup Condition="'@(_GenSourceProjectReference)' != ''">
      <Compile Remove="@(Compile)" />
      <Compile Include="@(_GenOrderedCompile)" />
    </ItemGroup>
  </Target>
</Project>
